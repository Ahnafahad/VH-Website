# VAPID Keys for Web Push Notifications
# Generate with: node scripts/generate-vapid.js
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# EmailJS Configuration (Client-side emails)
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_template_id_here
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_public_key_here

# Resend Configuration (Server-side registration notifications + LexiCore emails)
RESEND_API_KEY=your_resend_api_key_here

# Cron Job Secret (authenticates /api/cron/* routes called by Vercel)
# Generate with: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# Google OAuth Configuration (Required for NextAuth + Mental Math Trainer)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# Public copy of GOOGLE_CLIENT_ID — used by the Capacitor native Google sign-in bridge
# Must be identical to GOOGLE_CLIENT_ID above
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:6960
NEXTAUTH_SECRET=your_nextauth_secret_here

# MongoDB Configuration (Required for Mental Math leaderboards)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority

# ─── LMS: Cloudflare R2 (video storage) ──────────────────────────────────────
# Account ID from Cloudflare dashboard (Workers & Pages → R2 → Overview)
R2_ACCOUNT_ID=your_r2_account_id_here
# R2 API token with Object Read & Write permissions
R2_ACCESS_KEY_ID=your_r2_access_key_id_here
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key_here
# Name of the R2 bucket (e.g. "vh-recordings")
R2_BUCKET=your_r2_bucket_name_here

# ─── LMS: Recall.ai (auto-recording bot) ─────────────────────────────────────
# API key from app.recall.ai → Settings → API Keys
RECALL_API_KEY=your_recall_api_key_here
# Secret used to verify incoming Recall webhook signatures
RECALL_WEBHOOK_SECRET=your_recall_webhook_secret_here

# (BLOB_READ_WRITE_TOKEN removed — all file storage now uses Cloudflare R2 above)

# ─── LMS: Google Calendar (auto Meet creation) ───────────────────────────────
# OAuth2 redirect URI for the host-account Calendar consent flow (NOT NextAuth)
# e.g. https://yourdomain.com/api/admin/google/callback
GOOGLE_CALENDAR_REDIRECT_URI=http://localhost:6960/api/admin/google/callback

# Instructions:
# 1. Copy this file to .env.local
# 2. Sign up at https://www.emailjs.com/ (for client-side emails)
# 3. Create a service (Gmail, Outlook, etc.)
# 4. Create an email template
# 5. Sign up at https://resend.com/ (for server-side registration notifications)
#    - Get your API key from the Resend dashboard
#    - Add and verify your domain (optional, can use onboarding@resend.dev for testing)
# 6. Set up Google OAuth at https://console.developers.google.com/
# 7. Set up MongoDB Atlas at https://www.mongodb.com/atlas
# 8. Generate a NextAuth secret: openssl rand -base64 32
# 9. Replace the values above with your actual credentials
# 10. The EmailJS template should include these variables:
#     - {{to_email}}
#     - {{from_name}}
#     - {{from_email}}
#     - {{subject}}
#     - {{message}}