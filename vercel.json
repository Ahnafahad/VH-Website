{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["bom1"],
  "crons": [
    {
      "path": "/api/vocab/cron/weekly-reset",
      "schedule": "0 18 * * 6"
    },
    {
      "path": "/api/vocab/cron/decay",
      "schedule": "30 18 * * *"
    },
    {
      "path": "/api/cron/weekly-summary",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/check-streaks",
      "schedule": "10 18 * * *"
    },
    {
      "path": "/api/cron/email-warmup",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/email-warmup",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/registration-blast",
      "schedule": "0 4 14 6 *"
    },
    {
      "path": "/api/cron/orientation-blast",
      "schedule": "0 2 24 6 *"
    }
  ]
}
